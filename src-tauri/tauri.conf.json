{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Syncology",
  "version": "0.1.0",
  "identifier": "com.pusync.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Syncology",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM2NDFEODM0NUNGM0FGRkUKUldUK3IvTmNOTmhCeHRURmFEY25rZjh3WEdLOGVmZTk1SUwxREZ0ZW5LVSt6enZIdVN2ZVQ4cmsK",
      "endpoints": [
        "https://github.com/alertxsto/syncology-rust/releases/download/nightly/latest.json",
        "https://github.com/alertxsto/syncology-rust/releases/latest/download/latest.json"
      ]
    }
  }
}
